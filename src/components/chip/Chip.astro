---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  level?: "novice" | "proficient" | "professional";
  showLevel?: boolean;
  className?: string;
}

const {
  title,
  level = "proficient",
  showLevel = true,
  className = "",
} = Astro.props;

const filledBars = {
  novice: 1,
  proficient: 2,
  professional: 3,
}[level];
---

<div
  class:list={["chip", !showLevel && "chip--without-level", className]}
  data-level={level}
>
  <div class="chip__header">
    <div class="chip__icon" aria-hidden>
      <slot name="icon">
        <Icon name="swatch" size={18} aria-hidden />
      </slot>
    </div>
    <span class="chip__title">{title}</span>
  </div>
  {
    showLevel && (
      <div class="chip__bars" role="img" aria-label={`${level} proficiency`}>
        <span class:list={["chip__bar", filledBars >= 1 && "chip__bar--filled"]} />
        <span class:list={["chip__bar", filledBars >= 2 && "chip__bar--filled"]} />
        <span class:list={["chip__bar", filledBars >= 3 && "chip__bar--filled"]} />
      </div>
    )
  }
</div>
