---
import { Icon } from "astro-icon/components";

const {
  controls = "hero hero-starfield ambient-starfield tagline about-photo-carousel",
  iconOnly = false,
} = Astro.props;
---

<div class="motion-pause-wrap">
  <div class="sr-only" id="motionAnnouncement" role="status" aria-live="polite"></div>
  <button
    type="button"
    id="motionPauseToggle"
    class:list={[
      "motion-pause-button flex items-center gap-2",
      iconOnly && "motion-pause-button--icon-only",
    ]}
    aria-pressed="false"
    aria-controls={controls}
    aria-describedby="motionPauseDesc"
    aria-labelledby="motionPauseLabel"
  >
    <Icon
      name="pause"
      size={24}
      class="motion-pause-icon motion-toggle-icon"
      aria-hidden="true"
    />
    <Icon
      name="play"
      size={24}
      class="motion-play-icon motion-toggle-icon"
      aria-hidden="true"
    />
    <span id="motionPauseLabel">Pause animations</span>
  </button>
  <span id="motionPauseDesc" class="sr-only">
    Pauses or resumes the hero starfield, page background stars, tagline reveal, and
    photo carousel.
  </span>
</div>

<script is:inline>
  const getPausedAnimationStore = () => {
    if (!window.__portfolioPausedAnimations) {
      window.__portfolioPausedAnimations = [];
    }
    return window.__portfolioPausedAnimations;
  };

  const freezeDocumentAnimations = () => {
    const store = getPausedAnimationStore();
    store.length = 0;
    document.getAnimations().forEach((animation) => {
      if (animation.playState === "running" || animation.playState === "pending") {
        animation.pause();
        store.push(animation);
      }
    });
  };

  const resumeDocumentAnimations = () => {
    const store = getPausedAnimationStore();
    store.splice(0).forEach((animation) => {
      if (animation.playState === "paused") animation.play();
    });
  };

  const applyMotionPaused = (paused) => {
    if (paused) freezeDocumentAnimations();
    document.documentElement.classList.toggle("motion-paused", paused);
    localStorage.setItem("motionPaused", paused ? "true" : "false");

    const btn = document.getElementById("motionPauseToggle");
    const label = document.getElementById("motionPauseLabel");
    if (btn) {
      btn.setAttribute("aria-pressed", paused ? "true" : "false");
    }
    if (label) {
      label.textContent = paused ? "Play animations" : "Pause animations";
    }

    const announcement = document.getElementById("motionAnnouncement");
    if (announcement) {
      announcement.textContent = paused ? "Animations paused" : "Animations playing";
      window.setTimeout(() => {
        announcement.textContent = "";
      }, 1000);
    }

    window.dispatchEvent(
      new CustomEvent("motion-pause-change", { detail: { paused } }),
    );

    if (!paused) {
      // Let pause-aware components restore their clocks before playback resumes.
      requestAnimationFrame(resumeDocumentAnimations);
    } else {
      // Catch animations created by a component render responding to the pause event.
      requestAnimationFrame(() => {
        document.getAnimations().forEach((animation) => {
          if (animation.playState === "running" || animation.playState === "pending") {
            animation.pause();
            getPausedAnimationStore().push(animation);
          }
        });
      });
    }
  };

  const initMotionPause = () => {
    const paused = localStorage.getItem("motionPaused") === "true";
    applyMotionPaused(paused);

    const btn = document.getElementById("motionPauseToggle");
    if (!btn) return;

    btn.addEventListener("click", () => {
      const next = !document.documentElement.classList.contains("motion-paused");
      applyMotionPaused(next);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMotionPause);
  } else {
    initMotionPause();
  }
</script>
