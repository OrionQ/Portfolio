---
import { Icon } from "astro-icon/components";

const themes = ["blue", "pink", "green", "brown", "mono", "retro"];
---

<div class="theme-controls">
  <div class="sr-only" role="status" aria-live="polite" id="themeAnnouncement"></div>

  <div class="theme-picker-desktop" role="group" aria-label="Color theme selector">
    {themes.map((theme) => (
      <button
        class="theme-button"
        data-theme={theme}
        aria-label={`Select ${theme} theme`}
        aria-pressed="false"
        title={theme.charAt(0).toUpperCase() + theme.slice(1)}
      >
        <span class="color-swatch" aria-hidden="true"></span>
      </button>
    ))}
  </div>

  <div class="theme-dropdown">
    <button
      class="theme-dropdown-button"
      id="themeDropdownButton"
      aria-label="Open color theme menu"
      aria-expanded="false"
    >
      <Icon name="swatch" size={24} aria-hidden="true" />
    </button>
    <div id="themePicker" class="theme-picker-mobile" role="menu" aria-label="Color theme selector">
      {themes.map((theme) => (
        <button
          class="theme-button"
          data-theme={theme}
          aria-label={`Select ${theme} theme`}
          aria-pressed="false"
          title={theme.charAt(0).toUpperCase() + theme.slice(1)}
          role="menuitem"
        >
          <span class="color-swatch" aria-hidden="true"></span>
        </button>
      ))}
    </div>
  </div>

  <button
    id="darkModeToggle"
    class="icon-toggle"
    aria-label="Toggle light and dark mode"
    aria-pressed="false"
  >
    <Icon name="sun" size={24} class="theme-sun-icon theme-toggle-icon" aria-hidden="true" />
    <Icon name="moon" size={24} class="theme-moon-icon theme-toggle-icon" aria-hidden="true" />
  </button>
</div>

<script is:inline>
  const resolveDark = () => {
    const saved = localStorage.getItem("theme");
    if (saved === "dark") return true;
    if (saved === "light") return false;
    return window.matchMedia("(prefers-color-scheme: dark)").matches;
  };

  const announceTheme = (message) => {
    const el = document.getElementById("themeAnnouncement");
    if (el) {
      el.textContent = message;
      setTimeout(() => { el.textContent = ""; }, 1000);
    }
  };

  const updateThemeButtons = (theme) => {
    document.querySelectorAll(".theme-button").forEach((button) => {
      const active = button.dataset.theme === theme;
      button.classList.toggle("active", active);
      button.setAttribute("aria-pressed", active ? "true" : "false");
    });
  };

  const applyColorMode = () => {
    const isDark = resolveDark();
    document.documentElement.classList.toggle("dark", isDark);
    document
      .getElementById("darkModeToggle")
      ?.setAttribute("aria-pressed", isDark ? "true" : "false");
  };

  // Blue is the first-visit default. A visitor's deliberate picker choice is retained.
  const initialTheme = localStorage.getItem("colorTheme") || "blue";
  document.documentElement.setAttribute("data-theme", initialTheme);
  updateThemeButtons(initialTheme);
  applyColorMode();

  document.getElementById("darkModeToggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.contains("dark");
    const next = isDark ? "light" : "dark";
    localStorage.setItem("theme", next);
    document.documentElement.classList.toggle("dark", !isDark);
    document
      .getElementById("darkModeToggle")
      ?.setAttribute("aria-pressed", !isDark ? "true" : "false");
    announceTheme(`${next === "dark" ? "Dark" : "Light"} mode activated`);
  });

  document.querySelectorAll(".theme-button").forEach((button) => {
    button.addEventListener("click", () => {
      const theme = button.dataset.theme;
      if (!theme) return;
      document.documentElement.setAttribute("data-theme", theme);
      localStorage.setItem("colorTheme", theme);
      updateThemeButtons(theme);
      document.getElementById("themePicker")?.classList.remove("show");
      document.getElementById("themeDropdownButton")?.setAttribute("aria-expanded", "false");
      announceTheme(`${theme.charAt(0).toUpperCase() + theme.slice(1)} theme selected`);
    });
  });

  const dropdownButton = document.getElementById("themeDropdownButton");
  const picker = document.getElementById("themePicker");
  dropdownButton?.addEventListener("click", (event) => {
    event.stopPropagation();
    const open = picker?.classList.toggle("show") ?? false;
    dropdownButton.setAttribute("aria-expanded", open ? "true" : "false");
  });

  document.addEventListener("click", (event) => {
    if (!picker?.classList.contains("show")) return;
    if (!picker.contains(event.target) && event.target !== dropdownButton) {
      picker.classList.remove("show");
      dropdownButton?.setAttribute("aria-expanded", "false");
    }
  });

  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (event) => {
    const saved = localStorage.getItem("theme");
    if (saved === "dark" || saved === "light") return;
    document.documentElement.classList.toggle("dark", event.matches);
    document
      .getElementById("darkModeToggle")
      ?.setAttribute("aria-pressed", event.matches ? "true" : "false");
  });
</script>
