---
import { Icon } from "astro-icon/components";
import Divider from "../components/divider/Divider.astro";
import HeroStarfield from "../components/hero/HeroStarfield";
import Tag from "../components/tag/Tag.astro";

import Link from "../components/link/Link.astro";
import Layout from "../layouts/Layout.astro";
import Projects from "../section/Projects.astro";
import TaglineScratch from "../components/tagline/TaglineScratch";

// Edit these to change how the homepage may appear in Google results.
const pageTitle = "Orion's Portfolio";
const pageDescription =
  "Hi, Welcome! I'm Xiaolei Qin, and you may know me as Orion. I'm a software engineer and UX designer who builds thoughtful interfaces and improves user experiences.";
---

<script>
  const arrow = document.getElementById("scroll-arrow");
  const targetSection = document.querySelector("#projects");
  const heroBlock = document.querySelector<HTMLElement>(".hero-block");
  const headerOuter = document.querySelector<HTMLElement>(".header-outer");
  const PIN_MAX = 431;
  const MOBILE_SCROLL_STEPS = 8;
  const MOBILE_SEGMENT_VH = 82;

  let hoverChipIndex = -1;
  let lastScrollFocus = -2;
  let pinRaf = 0;
  let userInitiatedHeroScroll = false;
  let pinnedRunwayPx = 0;
  let stableViewportHeight = 0;
  let stableViewportWidth = window.innerWidth;
  let cachedPinTop = 0;
  let easterEggBuffer = "";
  let easterEggTimer = 0;
  let easterEggIndex = -1;
  let easterEggRemaining = 6500;
  let easterEggStartedAt = 0;
  let easterEggAutoRelease = true;

  const canHoverChips = () => window.innerWidth >= PIN_MAX;

  const measureLargeViewportHeight = () => {
    const probe = document.createElement("div");
    probe.style.cssText =
      "position:fixed;inset:0 auto auto 0;width:1px;height:100lvh;visibility:hidden;pointer-events:none;";
    document.body.append(probe);
    const measured = probe.offsetHeight;
    probe.remove();
    return (
      measured ||
      Math.max(window.innerHeight, window.visualViewport?.height ?? 0)
    );
  };

  const syncStableViewport = () => {
    if (!heroBlock) return;
    stableViewportHeight = measureLargeViewportHeight();
    stableViewportWidth = window.innerWidth;
    pinnedRunwayPx =
      MOBILE_SCROLL_STEPS * MOBILE_SEGMENT_VH * (stableViewportHeight / 100);
    heroBlock.style.setProperty(
      "--hero-layout-height",
      `${stableViewportHeight}px`,
    );
    heroBlock.style.setProperty("--hero-scroll-runway", `${pinnedRunwayPx}px`);
  };

  const invalidatePinnedRunway = () => {
    pinnedRunwayPx = 0;
  };

  const measurePinnedRunway = () => {
    if (!heroBlock) return 0;
    if (stableViewportHeight <= 0) syncStableViewport();
    return (
      pinnedRunwayPx ||
      MOBILE_SCROLL_STEPS * MOBILE_SEGMENT_VH * (stableViewportHeight / 100)
    );
  };

  const getHeroScrollRunway = () => {
    if (!heroBlock) return 0;
    if (!isPinnedHero()) {
      pinnedRunwayPx = 0;
      return Math.max(heroBlock.offsetHeight - window.innerHeight, 0);
    }
    if (pinnedRunwayPx <= 0) pinnedRunwayPx = measurePinnedRunway();
    return pinnedRunwayPx;
  };

  const syncPinTop = () => {
    cachedPinTop = headerOuter
      ? Math.ceil(headerOuter.getBoundingClientRect().height)
      : 88;
  };

  const arrowObserver = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        arrow?.classList.add("opacity-0");
      } else {
        arrow?.classList.remove("opacity-0");
      }
    },
    { threshold: 0.1 },
  );

  if (targetSection) {
    arrowObserver.observe(targetSection);
  }

  const osReducedMotion = () =>
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const motionPaused = () =>
    document.documentElement.classList.contains("motion-paused");

  const heroMotionFrozen = () => osReducedMotion() || motionPaused();

  const isPinnedHero = () => window.innerWidth < PIN_MAX;

  const getCurrentScrolled = () => {
    if (!heroBlock) return 0;
    const runway = getHeroScrollRunway();
    if (runway <= 0) return 0;
    return Math.min(
      Math.max(-heroBlock.getBoundingClientRect().top, 0),
      runway,
    );
  };

  const getRunwayInfo = () => {
    const runway = getHeroScrollRunway();
    const staged = isPinnedHero();
    const steps = staged ? MOBILE_SCROLL_STEPS : 1;
    const segment = runway > 0 ? runway / steps : 0;
    return { runway, segment, steps, staged };
  };

  const dispatchHeroFocus = (detail: number) => {
    if (detail === lastScrollFocus) return;
    lastScrollFocus = detail;
    window.dispatchEvent(new CustomEvent("hero-focus", { detail }));
  };

  const releaseEasterEgg = (returnToScroll = false) => {
    window.clearTimeout(easterEggTimer);
    easterEggTimer = 0;
    easterEggIndex = -1;
    easterEggRemaining = 6500;
    easterEggAutoRelease = true;
    if (hoverChipIndex < 0) {
      lastScrollFocus = -2;
      if (isPinnedHero() && (returnToScroll || getCurrentScrolled() > 2)) {
        window.dispatchEvent(
          new CustomEvent("hero-focus", {
            detail: { idx: -1, handoffToScroll: true },
          }),
        );
        updateHeroScrollPin();
      } else {
        dispatchHeroFocus(-1);
      }
    }
  };

  const scheduleEasterEggRelease = () => {
    if (motionPaused() || easterEggIndex < 0 || !easterEggAutoRelease) return;
    easterEggStartedAt = Date.now();
    easterEggTimer = window.setTimeout(releaseEasterEgg, easterEggRemaining);
  };

  const showEasterEgg = (index: number, autoRelease = true) => {
    window.clearTimeout(easterEggTimer);
    easterEggIndex = index;
    easterEggRemaining = 6500;
    easterEggAutoRelease = autoRelease;
    lastScrollFocus = index;
    heroBlock?.style.setProperty("--hero-scroll-active", "0");
    window.dispatchEvent(new CustomEvent("hero-focus", { detail: index }));
    if (autoRelease) scheduleEasterEggRelease();
  };

  const markHeroScrollIntent = () => {
    if (isPinnedHero() && easterEggIndex === 3) {
      releaseEasterEgg(true);
    }
    if (!isPinnedHero() || userInitiatedHeroScroll || heroMotionFrozen())
      return;
    if (pinnedRunwayPx <= 0) pinnedRunwayPx = measurePinnedRunway();
    userInitiatedHeroScroll = true;
    updateHeroScrollPin();
  };

  const updateHeroScrollPin = () => {
    if (!heroBlock) return;

    if (window.innerWidth >= PIN_MAX) {
      heroBlock.style.removeProperty("--hero-progress");
      heroBlock.style.removeProperty("--hero-pin-top");
      heroBlock.style.removeProperty("--hero-scroll-step");
      heroBlock.style.removeProperty("--hero-scroll-phase");
      heroBlock.style.removeProperty("--hero-scroll-active");
      heroBlock.style.removeProperty("--hero-runway-progress");
      lastScrollFocus = -2;
      userInitiatedHeroScroll = false;
      return;
    }

    const pinTop = cachedPinTop;
    heroBlock.style.setProperty("--hero-pin-top", `${pinTop}px`);

    const { runway, segment, staged } = getRunwayInfo();

    if (osReducedMotion()) {
      heroBlock.style.setProperty("--hero-progress", "1");
      heroBlock.style.setProperty(
        "--hero-scroll-step",
        String(MOBILE_SCROLL_STEPS - 1),
      );
      heroBlock.style.setProperty(
        "--hero-scroll-phase",
        String(MOBILE_SCROLL_STEPS),
      );
      heroBlock.style.setProperty("--hero-scroll-active", "1");
      return;
    }

    if (runway <= 0) {
      heroBlock.style.setProperty("--hero-progress", "0");
      heroBlock.style.setProperty("--hero-scroll-step", "0");
      heroBlock.style.setProperty("--hero-scroll-phase", "0");
      heroBlock.style.setProperty("--hero-scroll-active", "0");
      return;
    }

    const scrolled = getCurrentScrolled();
    const atHeroTop = scrolled <= 2;

    if (!atHeroTop && scrolled > 2) userInitiatedHeroScroll = true;

    const phase = staged && segment > 0 ? scrolled / segment : 0;
    const step = staged
      ? Math.min(Math.floor(phase), MOBILE_SCROLL_STEPS - 1)
      : 0;
    const textProgress = staged ? Math.min(1, phase) : scrolled / runway;
    const runwayProgress = runway > 0 ? scrolled / runway : 0;

    heroBlock.style.setProperty(
      "--hero-runway-progress",
      String(runwayProgress),
    );

    if (hoverChipIndex >= 0 || easterEggIndex >= 0) {
      heroBlock.style.setProperty("--hero-scroll-active", "0");
      return;
    }

    const rawScrolled = Math.max(-heroBlock.getBoundingClientRect().top, 0);
    const exited = runway > 0 && rawScrolled >= runway - 1;
    if (exited) {
      heroBlock.style.setProperty("--hero-progress", String(textProgress));
      heroBlock.style.setProperty("--hero-scroll-step", String(step));
      heroBlock.style.setProperty("--hero-scroll-active", "0");
      heroBlock.style.setProperty(
        "--hero-scroll-phase",
        String(MOBILE_SCROLL_STEPS),
      );
      dispatchHeroFocus(-1);
      return;
    }

    if (atHeroTop) {
      userInitiatedHeroScroll = false;
      invalidatePinnedRunway();
      heroBlock.style.setProperty("--hero-progress", "0");
      heroBlock.style.setProperty("--hero-scroll-step", "0");
      heroBlock.style.setProperty("--hero-scroll-phase", "0");
      heroBlock.style.setProperty("--hero-scroll-active", "0");
      return;
    }

    heroBlock.style.setProperty("--hero-progress", String(textProgress));
    heroBlock.style.setProperty("--hero-scroll-step", String(step));

    if (!userInitiatedHeroScroll) {
      heroBlock.style.setProperty("--hero-scroll-phase", "0");
      heroBlock.style.setProperty("--hero-scroll-active", "0");
      return;
    }

    heroBlock.style.setProperty(
      "--hero-scroll-phase",
      String(Math.min(phase, MOBILE_SCROLL_STEPS)),
    );
    heroBlock.style.setProperty("--hero-scroll-active", "1");
  };

  const scheduleHeroScrollPin = () => {
    if (pinRaf) return;
    pinRaf = requestAnimationFrame(() => {
      pinRaf = 0;
      updateHeroScrollPin();
    });
  };

  const releaseChipHover = () => {
    if (hoverChipIndex < 0) return;
    hoverChipIndex = -1;
    lastScrollFocus = -2;
    if (isPinnedHero()) {
      updateHeroScrollPin();
      return;
    }
    dispatchHeroFocus(-1);
  };

  const syncChipHoverMode = () => {
    if (!canHoverChips()) releaseChipHover();
  };

  syncStableViewport();
  syncPinTop();
  updateHeroScrollPin();
  window.addEventListener(
    "scroll",
    () => {
      if (isPinnedHero() && easterEggIndex === 3) {
        releaseEasterEgg(true);
      }
      scheduleHeroScrollPin();
    },
    { passive: true },
  );
  window.addEventListener("wheel", markHeroScrollIntent, { passive: true });
  window.addEventListener("touchmove", markHeroScrollIntent, { passive: true });
  window.visualViewport?.addEventListener("resize", () => {
    if (!isPinnedHero()) return;
    syncPinTop();
    scheduleHeroScrollPin();
  });
  window.addEventListener(
    "keydown",
    (e) => {
      if (
        [
          "ArrowDown",
          "ArrowUp",
          "PageDown",
          "PageUp",
          " ",
          "End",
          "Home",
        ].includes(e.key)
      ) {
        markHeroScrollIntent();
      }

      const target = e.target as HTMLElement | null;
      const isTypingField =
        target?.matches("input, textarea, select, [contenteditable='true']") ??
        false;
      if (
        isTypingField ||
        e.metaKey ||
        e.ctrlKey ||
        e.altKey ||
        e.key.length !== 1
      )
        return;

      easterEggBuffer = `${easterEggBuffer}${e.key.toLowerCase()}`.slice(-8);
      const secretIndex = easterEggBuffer.endsWith("cancer")
        ? 4
        : easterEggBuffer.endsWith("orion")
          ? 3
          : -1;
      if (secretIndex < 0) return;

      easterEggBuffer = "";
      showEasterEgg(secretIndex);
    },
    { passive: true },
  );
  window.addEventListener("resize", () => {
    syncPinTop();
    const widthChanged = Math.abs(window.innerWidth - stableViewportWidth) > 20;
    if (widthChanged) syncStableViewport();
    if (!isPinnedHero()) {
      userInitiatedHeroScroll = false;
      invalidatePinnedRunway();
    }
    updateHeroScrollPin();
    syncChipHoverMode();
  });
  window.addEventListener("orientationchange", () => {
    window.setTimeout(() => {
      syncStableViewport();
      syncPinTop();
      updateHeroScrollPin();
    }, 150);
  });
  window.addEventListener("motion-pause-change", (e) => {
    const paused = Boolean(
      (e as CustomEvent<{ paused?: boolean }>).detail?.paused,
    );
    if (easterEggIndex >= 0) {
      if (paused && easterEggTimer) {
        window.clearTimeout(easterEggTimer);
        easterEggTimer = 0;
        easterEggRemaining = Math.max(
          0,
          easterEggRemaining - (Date.now() - easterEggStartedAt),
        );
      } else if (!paused) {
        scheduleEasterEggRelease();
      }
    }
    updateHeroScrollPin();
  });

  // Chip hover: enabled above 431px; pinned scroll scrubs sphere rotation below that.
  const chips = document.querySelectorAll<HTMLElement>(".roles .tag");
  chips.forEach((chip, i) => {
    chip.addEventListener("mouseenter", () => {
      if (!canHoverChips()) return;
      window.clearTimeout(easterEggTimer);
      hoverChipIndex = i;
      lastScrollFocus = i;
      window.dispatchEvent(new CustomEvent("hero-focus", { detail: i }));
    });
    chip.addEventListener("mouseleave", () => {
      if (!canHoverChips()) return;
      releaseChipHover();
    });
  });

  const orionTrigger = document.getElementById("hero-secret-trigger");

  orionTrigger?.addEventListener("mouseenter", () => showEasterEgg(3, false));
  orionTrigger?.addEventListener("mouseleave", () => releaseEasterEgg());
  orionTrigger?.addEventListener("click", () => showEasterEgg(3));
</script>

<Layout title={pageTitle} description={pageDescription}>
  <div class="hero-block" slot="hero">
    <section class="hero" id="hero" aria-label="Introduction" tabindex="-1">
      <HeroStarfield client:load />
      <div class="hero__inner">
        <div class="hero__text-stage">
          <div
            class="hero__text flex flex-col gap-8 w-full scroll-content opacity-0 translate-y-10 transition-[opacity,transform] duration-500"
          >
            <div
              class="flex flex-col gap-2 items-center text-center lg:items-start lg:text-start w-full"
            >
              <h1 class="text-4xl xl:text-5xl py-4 lg:py-8 w-full">
                Hey, I'm <button
                  type="button"
                  id="hero-secret-trigger"
                  class="hero-secret-trigger"
                  tabindex="-1"
                  aria-label="Reveal a hidden constellation">Orion!</button
                >
              </h1>
              <TaglineScratch client:load />
              <p class="xl:text-lg">That's why I keep designing and coding.</p>
            </div>
            <div
              class="roles flex flex-row flex-wrap gap-2 justify-center lg:justify-start"
            >
              <Tag>Software Engineer</Tag>
              <Tag>UX Designer</Tag>
              <Tag>Photographer</Tag>
            </div>
          </div>
        </div>
      </div>
      <Icon
        name="chevron-down"
        id="scroll-arrow"
        size={32}
        class="hero-chevron shrink-0 animate-float-slow transition-opacity duration-500"
        aria-hidden
        color="rgba(var(--floating-color), 1)"
      />
    </section>
  </div>
  <Divider dividerType="tertiary" />
  <!-- Projects Section -->
  <Projects />
  <section class="flex justify-center py-12">
    <Link
      underline
      href="/experience"
      className="text-xl font-medium inline-flex items-center gap-2"
    >
      Check out my experience
      <Icon name="arrow-right-long" size={20} aria-hidden />
    </Link>
  </section>
</Layout>
