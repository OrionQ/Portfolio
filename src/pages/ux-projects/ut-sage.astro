<script>
  if (typeof window !== "undefined") {
    window.addEventListener("DOMContentLoaded", () => {
      const tabOrder = ["redesignCase", "capstoneCase"];

      const tabButtonId = {
        redesignCase: "tab-redesign-case",
        capstoneCase: "tab-capstone-case",
      };

      const container = document.querySelector(".case-tabs-container");
      const indicator = document.getElementById("case-tab-indicator");

      const updateIndicator = (instant = false) => {
        const selected = document.querySelector(
          '.case-tab-button[aria-selected="true"]',
        );
        if (
          !indicator ||
          !container ||
          !selected ||
          !(selected instanceof HTMLElement)
        )
          return;
        if (instant) {
          indicator.classList.add("case-tab-indicator--snap");
        }
        indicator.style.left = `${selected.offsetLeft}px`;
        indicator.style.width = `${selected.offsetWidth}px`;
        if (instant) {
          void indicator.offsetWidth;
          indicator.classList.remove("case-tab-indicator--snap");
        }
      };

      const focusTabButton = (caseKey) => {
        document.getElementById(tabButtonId[caseKey])?.focus();
      };

      const showCase = (caseKey) => {
        for (const key of tabOrder) {
          const panel = document.getElementById(key);
          if (!panel) continue;
          if (key === caseKey) {
            panel.removeAttribute("hidden");
          } else {
            panel.setAttribute("hidden", "");
          }
        }

        document.querySelectorAll(".case-tab-button").forEach((button) => {
          const sel = button.getAttribute("data-case") === caseKey;
          button.setAttribute("aria-selected", sel ? "true" : "false");
          if (button instanceof HTMLElement) button.tabIndex = sel ? 0 : -1;
        });

        focusTabButton(caseKey);
        requestAnimationFrame(() => updateIndicator());
      };

      container?.addEventListener("keydown", (e) => {
        if (!(e instanceof KeyboardEvent)) return;
        if (!(e.target instanceof HTMLElement)) return;
        if (!e.target.classList.contains("case-tab-button")) return;

        const ix = tabOrder.indexOf(e.target.dataset.case ?? "");
        if (ix === -1) return;

        if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          e.preventDefault();
          showCase(tabOrder[(ix + 1) % tabOrder.length]);
          return;
        }
        if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault();
          showCase(tabOrder[(ix - 1 + tabOrder.length) % tabOrder.length]);
          return;
        }
        if (e.key === "Home") {
          e.preventDefault();
          showCase("redesignCase");
          return;
        }
        if (e.key === "End") {
          e.preventDefault();
          showCase("capstoneCase");
        }
      });

      updateIndicator(true);
      requestAnimationFrame(() => updateIndicator(true));
      window.addEventListener("resize", () => updateIndicator());

      document
        .getElementById("tab-redesign-case")
        ?.addEventListener("click", () => {
          showCase("redesignCase");
        });
      document
        .getElementById("tab-capstone-case")
        ?.addEventListener("click", () => {
          showCase("capstoneCase");
        });
    });
  }
</script>

