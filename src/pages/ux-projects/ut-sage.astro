            alt="Tutor evaluation dashboard — key findings, overview, and Suggestions & Recommendations"
            width={2000}
            quality={100}
            class="rounded-xl w-full h-auto object-contain"
          />
        </figure>
      </div>

      <div class="process-section">
        <div class="flex gap-4">
          <div
            class="process-item-odd flex flex-col justify-center w-full"
            id="capstone-goal"
          >
            <h3>1. Goal</h3>
            <br />
            <p>
              <strong>Problem:</strong> faculty could scaffold and publish tutors,
              but lacked a repeatable way to simulate learners, stress-test tutoring
              behavior, and reconcile configuration with pedagogical outcomes.
            </p>
            <br />
            <Card title="How might we?" cardType="secondary">
              <p class="text-base text-[rgba(var(--foreground-color),0.85)]">
                Help faculty confidently assess and refine tutor configurations
                before deployments, surfacing observable evidence, explainable
                ratings, and updates they can approve?
              </p>
            </Card>
            <br />
            <Card title="Design goal" cardType="secondary">
              <p class="text-base text-[rgba(var(--foreground-color),0.85)]">
                Pair approachable onboarding that builds mental models of each
                configuration fields with an evaluation dashboard that routes
                faculty from high-level warnings to granular checks,
                suggestions, examples, and simulated dialogue.
              </p>
            </Card>
          </div>
        </div>

        <div class="flex gap-4">
          <div
            class="process-item-even flex flex-col justify-center w-full"
            id="capstone-research"
          >
            <h3>2. Research and evaluation framework</h3>
            <br />
            <p>
              I paired secondary research with history user interview data from
              existing UT Sage papers to uncover configuration gaps, then
              translated benchmarks from AI evaluation literature into an
              instructor-readable scorecard anchored in classroom teaching
              moves.
            </p>
            <br />
            <Card
              title="8 evaluation dimensions (response quality)"
              cardType="secondary"
            >
              <ul
                class="list-disc pl-6 space-y-2 text-[rgba(var(--foreground-color),0.85)] text-base"
              >
                <li>
                  D1 Instruction-following — Honors faculty special
                  instructions.
                </li>
                <li>
                  D2 Truthfulness — Keeps explanations accurate; avoids
                  hallucinated content.
                </li>
                <li>
                  D3 Style / tone — Language is warm yet academically rigorous.
                </li>
                <li>
                  D4 Visual reasoning — Interprets and reasons about diagrams or
                  graphs.
                </li>
                <li>
                  D5 Visual perception — Reads visual inputs shared by learners.
                </li>
                <li>D6 Calibration — Pacing fits the learner profile.</li>
                <li>D7 Conciseness — Keeps replies scoped appropriately.</li>
                <li>
                  D8 Emotional responsiveness — Addresses frustration
                  constructively.
                </li>
              </ul>
            </Card>
            <br />
            <Card
              title="7 tutoring skills (instructional behaviors)"
              cardType="secondary"
            >
              <ul
                class="list-disc pl-6 space-y-2 text-[rgba(var(--foreground-color),0.85)] text-base"
              >
                <li>T1 Identifies misconceptions explicitly.</li>
                <li>
                  T2 Guides with questions instead of giving answers outright.
                </li>
                <li>T3 Uses examples and analogies to demystify ideas.</li>
                <li>T4 Offers alternate solution paths.</li>
                <li>T5 Scaffolds step-by-step when problems are dense.</li>
                <li>
                  T6 Recalls syllabus or uploaded resources when relevant.
                </li>
                <li>
                  T7 Judges correct/incorrect steps in learner work accurately.
                </li>
              </ul>
            </Card>
          </div>
        </div>

        <div class="flex gap-4">
          <div
            class="process-item-odd flex flex-col justify-center w-full gap-4"
            id="capstone-prototyping"
          >
            <h3>3. Prototyping</h3>
            <p>
              I iterated in Figma on two intertwined surfaces: contextual
              tutorial overlays explaining how Create, Configure, and Train map
              tutor memory, plus a consolidated evaluation concept that surfaced
              key findings before detail tabs.
            </p>
            <div
              class="capstone-proto-grid grid grid-cols-1 md:grid-cols-2 gap-4"
            >
              <figure class="capstone-figure">
                <figcaption
                  class="text-sm pb-2 text-[rgba(var(--foreground-color),0.72)] font-medium"
                >
                  Welcome modal — sets expectations and scope guardrails.
                </figcaption>
                <Image
                  format="png"
                  src={facultyEvalTutorialModal}
                  alt="Welcome to Create Your UT Sage Tutor modal"
                  width={2000}
                  quality={100}
                  class="rounded-xl w-full h-auto object-contain bg-[rgba(var(--floating-color),0.35)]"
                />
              </figure>
              <figure class="capstone-figure">
                <figcaption
                  class="text-sm pb-2 text-[rgba(var(--foreground-color),0.72)] font-medium"
                >
                  Orientation step — contextualizes Create, Configure, and
                  Train.
                </figcaption>
                <Image
                  format="png"
                  src={facultyEvalTutorialStep}
                  alt="Tutorial explaining Create Configure and Train sections"
                  width={2000}
                  quality={100}
                  class="rounded-xl w-full h-auto object-contain bg-[rgba(var(--floating-color),0.35)]"
                />
              </figure>
              <figure class="capstone-figure">
                <figcaption
                  class="text-sm pb-2 text-[rgba(var(--foreground-color),0.72)] font-medium"
                >
                  Chat scaffolding — alternative to manually type in every
                  field.
                </figcaption>
                <Image
                  format="png"
                  src={facultyEvalChatStep}
                  alt="Tutorial tooltip on tutor creation chat syncing fields"
                  width={2000}
                  quality={100}
                  class="rounded-xl w-full h-auto object-contain bg-[rgba(var(--floating-color),0.35)]"
                />
              </figure>
              <figure class="capstone-figure">
                <figcaption
                  class="text-sm pb-2 text-[rgba(var(--foreground-color),0.72)] font-medium"
                >
                  Configure cue — anchors different fields feeding calibration
                  logic.
                </figcaption>
                <Image
                  format="png"
                  src={facultyEvalConfigureStep}
                  alt="Tutorial tooltip on learner characteristics in Configure tab"
                  width={2000}
                  quality={100}
                  class="rounded-xl w-full h-auto object-contain bg-[rgba(var(--floating-color),0.35)]"
                />
              </figure>
            </div>
            <figure class="capstone-hero-thumb mt-2">
              <figcaption
                class="text-sm pb-2 text-[rgba(var(--foreground-color),0.72)] font-medium"
              >
                Early evaluation dashboard — How AI surfaces cross-field risks
                to the faculty.
              </figcaption>
              <Image
                format="png"
                src={facultyEvalThumbnail}
                alt="Full tutor evaluation concept showing key findings and overview"
                width={2000}
                quality={100}
                class="rounded-xl w-full h-auto object-contain"
              />
            </figure>
          </div>
        </div>

        <div class="flex gap-4">
          <div
            class="process-item-even flex flex-col justify-center w-full"
            id="capstone-interviews"
          >
            <h3>4. Faculty research — usability findings</h3>
            <br />
            <Card title="Method" cardType="secondary">
              <p class="text-base text-[rgba(var(--foreground-color),0.85)]">
                Moderated remote think-aloud (30–45 min) with UT Austin faculty
                / instructional partners evaluating two Figma prototypes: guided
                tutorial overlay + tutor evaluation UI.
              </p>
            </Card>
            <br />
            <Card title="Key findings" cardType="secondary">
              <ul
                class="list-disc pl-6 space-y-2 text-[rgba(var(--foreground-color),0.85)] text-base"
              >
                <li>
                  <strong>Tutorial &amp; language:</strong> The use of language is
                  confusing and doesn't contribute to the learning process, and multiple
                  participants mentioned that they would like to see more concrete
                  examples.
                </li>
                <li>
                  <strong>Cognitive load:</strong> empty states swung straight into
                  exhaustive detail on the evaluation page, and faculty feels overwhelmed
                  by the amount of information.
                </li>
                <li>
                  <strong>Fitness of the model:</strong> Faculty would like to see
                  if there is a way to customize the evaluation prompts to fit their
                  needs.
                </li>
                <li>
                  <strong>Surfacing severity:</strong> While the color coding is helpful,
                  some faculty would like to make sure accessibility is considered,
                  and additional color coding to grab their attention for critical
                  issues.
                  <li>
                    <strong>Evidence &amp; authenticity:</strong> Participants think
                    that auto-fix and heavy nudging need visible scope/consent boundaries
                    that protect instructor-authored ideas.
                  </li>
                </li>
              </ul>
            </Card>
          </div>
        </div>

        <div class="flex gap-4">
          <div
            class="process-item-odd flex flex-col justify-center w-full gap-6"
            id="capstone-iteration"
          >
            <h3>5. Iteration — reduce information overload</h3>
            <p>
              Research converged on the need to stage complexity: summarize
              risk, funnel faculty into prioritized remediations, only then
              expose field-by-field adjudication or bespoke simulation prompts.
            </p>
            <p>
              Each tab below isolates workloads to prevent the “everything at
              once” fatigue cited in moderated sessions while keeping
              cross-links for deep dives intact.
            </p>

            <div class="grid w-full grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8">
              <div
                class="capstone-iteration-figure flex min-w-0 flex-col gap-2"
              >
                <strong>Suggestions &amp; Recommendations</strong>
                <Image
                  format="png"
                  src={facultyEvalRecommendations}
                  alt="Tutor Evaluation tab showing key findings overview and suggestion cards"
                  width={2000}
                  quality={100}
                  class="rounded-xl w-full h-auto object-contain"
                />
              </div>
              <div
                class="capstone-iteration-figure flex min-w-0 flex-col gap-2"
              >
                <strong>Evaluation by field</strong>
                <Image
                  format="png"
                  src={facultyEvalByField}
                  alt="Evaluation by field table"
                  width={2000}
                  quality={100}
                  class="rounded-xl w-full h-auto object-contain"
                />
              </div>
              <div
                class="capstone-iteration-figure flex min-w-0 flex-col gap-2"
              >
                <strong>File management</strong>
                <Image
                  format="png"
                  src={facultyEvalFileManagement}
                  alt="File management tab listing syllabus and documents with statuses"
                  width={2000}
                  quality={100}
                  class="rounded-xl w-full h-auto object-contain"
                />
              </div>
              <div
                class="capstone-iteration-figure flex min-w-0 flex-col gap-2"
              >
                <strong
                  >Customize evaluation - An added feature from feedback</strong
                >
                <Image
                  format="png"
                  src={facultyEvalCustomize}
                  alt="Customize evaluation tab for additional benchmark questions"
                  width={2000}
                  quality={100}
                  class="rounded-xl w-full h-auto object-contain"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="flex gap-4">
          <div
            class="process-item-even flex flex-col justify-center w-full"
            id="capstone-future"
          >
            <h3>6. Future directions</h3>

            <ul class="list-disc pl-6 space-y-2 project-description">
              <li>
                Ship tutorial copy that aligns highlight, narration, and live UI
                state causality plus concrete examples to further clarify the
                configuration fields.
              </li>
              <li>
                Build explainable modality + labeling for simulations (simulated
                learner transcripts vs telemetry) and rethink Auto-fix so
                faculty stay authors of misconception content unless they
                opt-in.
              </li>
              <li>
                Follow-up moderated tests with Humanities + STEM instructors
                after engineering implementation; extend benchmark suites per
                discipline as adoption grows.
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <br />
    <div class="flex flex-row gap-8 justify-between w-full">
      <Link href="/" underline><Icon name="arrow-left-long" />Go back home</Link
      >
      <Link href="/ux-projects/venus" underline
        >Next case study: Venus<Icon name="arrow-right-long" /></Link
      >
    </div>
  </div>
</Layout>

